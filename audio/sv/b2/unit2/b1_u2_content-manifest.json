  {
    "contentId": "b2_dialog_line_001_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej! Vad heter du?",
    "audioRef": "sv_b1_u2_dialog_001_line_01_hej_vad_heter_du_v1"
  },
  {
    "contentId": "b2_dialog_line_001_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag heter Wei. Jag kommer från Kina och bor nu i Stockholm.",
    "audioRef": "sv_b1_u2_dialog_001_line_02_jag_heter_wei_jag_kommer_fran_kina_och_bor_nu_i_stockholm_v1"
  },
  {
    "contentId": "b2_dialog_line_001_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Vad arbetar du med?",
    "audioRef": "sv_b1_u2_dialog_001_line_03_vad_arbetar_du_med_v1"
  },
  {
    "contentId": "b2_dialog_line_001_04",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag studerar svenska nu. Tidigare jobbade jag som kock i Kina.",
    "audioRef": "sv_b1_u2_dialog_001_line_04_jag_studerar_svenska_nu_tidigare_jobbade_jag_som_kock_i_kina_v1"
  },
  {
    "contentId": "b2_dialog_line_001_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Talar du något annat språk?",
    "audioRef": "sv_b1_u2_dialog_001_line_05_talar_du_nagot_annat_sprak_v1"
  },
  {
    "contentId": "b2_dialog_line_001_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Ja, jag talar kinesiska och lite engelska. Jag förstår inte så mycket svenska än, men jag lär mig varje dag.",
    "audioRef": "sv_b1_u2_dialog_001_line_06_ja_jag_talar_kinesiska_och_lite_engelska_jag_forstar_inte_sa_mycket_svenska_an_men_jag_lar_v1"
  },
  {
    "contentId": "b2_dialog_line_002_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Vad gör du på morgonen?",
    "audioRef": "sv_b1_u2_dialog_002_line_01_vad_gor_du_pa_morgonen_v1"
  },
  {
    "contentId": "b2_dialog_line_002_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag går upp klockan sex, äter frukost och sedan tar jag bussen till skolan.",
    "audioRef": "sv_b1_u2_dialog_002_line_02_jag_gar_upp_klockan_sex_ater_frukost_och_sedan_tar_jag_bussen_till_skolan_v1"
  },
  {
    "contentId": "b2_dialog_line_002_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Handlar du mat varje dag?",
    "audioRef": "sv_b1_u2_dialog_002_line_03_handlar_du_mat_varje_dag_v1"
  },
  {
    "contentId": "b2_dialog_line_002_04",
    "audioType": "dialogue_line_group",
    "sourceText": "Nej, jag handlar två gånger i veckan. Jag köper oftast mat på ICA som finns nära mitt hus.",
    "audioRef": "sv_b1_u2_dialog_002_line_04_nej_jag_handlar_tva_ganger_i_veckan_jag_koper_oftast_mat_pa_ica_som_finns_nara_mitt_hus_v1"
  },
  {
    "contentId": "b2_dialog_line_002_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Vet du om det finns en bra restaurang här?",
    "audioRef": "sv_b1_u2_dialog_002_line_05_vet_du_om_det_finns_en_bra_restaurang_har_v1"
  },
  {
    "contentId": "b2_dialog_line_002_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Ja! Det finns en kinesisk restaurang på gatan här. Jag tror att de lagar mycket god mat.",
    "audioRef": "sv_b1_u2_dialog_002_line_06_ja_det_finns_en_kinesisk_restaurang_pa_gatan_har_jag_tror_att_de_lagar_mycket_god_mat_v1"
