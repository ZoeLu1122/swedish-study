    { "audioId": "sv_a4_u4_dialog_001_01", "sourceText": "Ursäkta, var finns brödet?",                          "fileName": "a1_u4_dialog_001_line_01_ursakta_var_finns_brodet_v1.mp3",              "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_001_line_01_ursakta_var_finns_brodet_v1.mp3",              "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_001_02", "sourceText": "Det är i gång tre, till höger.",                      "fileName": "a1_u4_dialog_001_line_02_det_ar_i_gang_tre_till_hoger_v1.mp3",           "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_001_line_02_det_ar_i_gang_tre_till_hoger_v1.mp3",           "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_001_03", "sourceText": "Tack! Vad kostar mjölken?",                           "fileName": "a1_u4_dialog_001_line_03_tack_vad_kostar_mjolken_v1.mp3",               "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_001_line_03_tack_vad_kostar_mjolken_v1.mp3",               "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_001_04", "sourceText": "Den kostar tjugofem kronor.",                          "fileName": "a1_u4_dialog_001_line_04_den_kostar_tjugofem_kronor_v1.mp3",            "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_001_line_04_den_kostar_tjugofem_kronor_v1.mp3",            "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_001_05", "sourceText": "Bra, jag tar den. Kan jag betala med kort?",          "fileName": "a1_u4_dialog_001_line_05_bra_jag_tar_den_kan_jag_betala_med_kort_v1.mp3","filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_001_line_05_bra_jag_tar_den_kan_jag_betala_med_kort_v1.mp3","status": "ready" },
    { "audioId": "sv_a4_u4_dialog_001_06", "sourceText": "Ja, självklart. Kassan är där borta.",                "fileName": "a1_u4_dialog_001_line_06_ja_sjalvklart_kassan_ar_dar_borta_v1.mp3",     "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_001_line_06_ja_sjalvklart_kassan_ar_dar_borta_v1.mp3",     "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_002_01", "sourceText": "Hej! Vad vill du ha?",                                "fileName": "a1_u4_dialog_002_line_01_hej_vad_vill_du_ha_v1.mp3",                   "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_002_line_01_hej_vad_vill_du_ha_v1.mp3",                   "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_002_02", "sourceText": "Hej! Jag vill ha en kaffe och en smörgås, tack.",     "fileName": "a1_u4_dialog_002_line_02_hej_jag_vill_ha_en_kaffe_och_en_smorgas_tack_v1.mp3","filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_002_line_02_hej_jag_vill_ha_en_kaffe_och_en_smorgas_tack_v1.mp3","status": "ready" },
    { "audioId": "sv_a4_u4_dialog_002_03", "sourceText": "Stor eller liten kaffe?",                             "fileName": "a1_u4_dialog_002_line_03_stor_eller_liten_kaffe_v1.mp3",               "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_002_line_03_stor_eller_liten_kaffe_v1.mp3",               "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_002_04", "sourceText": "En liten kaffe, tack. Vad kostar det?",              "fileName": "a1_u4_dialog_002_line_04_en_liten_kaffe_tack_vad_kostar_det_v1.mp3",  "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_002_line_04_en_liten_kaffe_tack_vad_kostar_det_v1.mp3",  "status": "ready" },
    { "audioId": "sv_a4_u4_dialog_002_05", "sourceText": "Det kostar fyrtio kronor tillsammans.",               "fileName": "a1_u4_dialog_002_line_05_det_kostar_fyrtio_kronor_tillsammans_v1.mp3","filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_002_line_05_det_kostar_fyrtio_kronor_tillsammans_v1.mp3","status": "ready" },
    { "audioId": "sv_a4_u4_dialog_002_06", "sourceText": "Varsågod!",                                           "fileName": "a1_u4_dialog_002_line_06_varsagod_v1.mp3",                             "filePath": "/audio/sv/a4/unit4/dialogue/a1_u4_dialog_002_line_06_varsagod_v1.mp3",                             "status": "ready" },
