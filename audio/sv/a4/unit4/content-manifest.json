  {
    "contentId": "a4_dialog_line_001_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Ursäkta, var finns brödet?",
    "audioRef": "sv_a4_u4_dialog_001_01"
  },
  {
    "contentId": "a4_dialog_line_001_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Det är i gång tre, till höger.",
    "audioRef": "sv_a4_u4_dialog_001_02"
  },
  {
    "contentId": "a4_dialog_line_001_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Tack! Vad kostar mjölken?",
    "audioRef": "sv_a4_u4_dialog_001_03"
  },
  {
    "contentId": "a4_dialog_line_001_04",
    "audioType": "dialogue_line_group",
    "sourceText": "Den kostar tjugofem kronor.",
    "audioRef": "sv_a4_u4_dialog_001_04"
  },
  {
    "contentId": "a4_dialog_line_001_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Bra, jag tar den. Kan jag betala med kort?",
    "audioRef": "sv_a4_u4_dialog_001_05"
  },
  {
    "contentId": "a4_dialog_line_001_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Ja, självklart. Kassan är där borta.",
    "audioRef": "sv_a4_u4_dialog_001_06"
  },
  {
    "contentId": "a4_dialog_line_002_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej! Vad vill du ha?",
    "audioRef": "sv_a4_u4_dialog_002_01"
  },
  {
    "contentId": "a4_dialog_line_002_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej! Jag vill ha en kaffe och en smörgås, tack.",
    "audioRef": "sv_a4_u4_dialog_002_02"
  },
  {
    "contentId": "a4_dialog_line_002_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Stor eller liten kaffe?",
    "audioRef": "sv_a4_u4_dialog_002_03"
  },
  {
    "contentId": "a4_dialog_line_002_04",
    "audioType": "dialogue_line_group",
    "sourceText": "En liten kaffe, tack. Vad kostar det?",
    "audioRef": "sv_a4_u4_dialog_002_04"
  },
  {
    "contentId": "a4_dialog_line_002_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Det kostar fyrtio kronor tillsammans.",
    "audioRef": "sv_a4_u4_dialog_002_05"
  },
  {
    "contentId": "a4_dialog_line_002_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Varsågod!",
    "audioRef": "sv_a4_u4_dialog_002_06"
  },
  {
    "contentId": "a4_dialog_line_002_07",
    "audioType": "dialogue_line_group",
    "sourceText": "Tack! Varsågod. Ha en bra dag!",
    "audioRef": "sv_a4_u4_dialog_002_07"
  },
