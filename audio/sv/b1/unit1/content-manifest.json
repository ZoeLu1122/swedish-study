  {
    "contentId": "b1_dialog_line_001_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej! Vad heter du och vad är ditt personnummer?",
    "audioRef": "sv_b1_u1_dialog_001_line_01_hej_vad_heter_du_och_vad_ar_ditt_personnummer"
  },
  {
    "contentId": "b1_dialog_line_001_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag heter Li Wei. Min adress är Storgatan 12 och mitt nummer är 850415-1234.",
    "audioRef": "sv_b1_u1_dialog_001_line_02_jag_heter_li_wei_min_adress_ar_storgatan_12_och_mitt_nummer_ar_850415_1234"
  },
  {
    "contentId": "b1_dialog_line_001_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Bra. Bor du i hus eller lägenhet?",
    "audioRef": "sv_b1_u1_dialog_001_line_03_bra_bor_du_i_hus_eller_lagenhet"
  },
  {
    "contentId": "b1_dialog_line_001_04",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag bor i en lägenhet. Lägenheten har tre rum.",
    "audioRef": "sv_b1_u1_dialog_001_line_04_jag_bor_i_en_lagenhet_lagenheten_har_tre_rum"
  },
  {
    "contentId": "b1_dialog_line_001_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Vilket land kommer du från?",
    "audioRef": "sv_b1_u1_dialog_001_line_05_vilket_land_kommer_du_fran"
  },
  {
    "contentId": "b1_dialog_line_001_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag kommer från Kina. Jag lär mig svenska. Skolan är bra och läraren är snäll.",
    "audioRef": "sv_b1_u1_dialog_001_line_06_jag_kommer_fran_kina_jag_lar_mig_svenska_skolan_ar_bra_och_lararen_ar_snall"
  },
  {
    "contentId": "b1_dialog_line_002_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej, är du ny granne här?",
    "audioRef": "sv_b1_u1_dialog_002_line_01_hej_ar_du_ny_granne_har"
  },
  {
    "contentId": "b1_dialog_line_002_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Ja! Jag heter Mei. Jag har en man, en son och en dotter.",
    "audioRef": "sv_b1_u1_dialog_002_line_02_ja_jag_heter_mei_jag_har_en_man_en_son_och_en_dotter"
  },
  {
    "contentId": "b1_dialog_line_002_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Vad jobbar din man med?",
    "audioRef": "sv_b1_u1_dialog_002_line_03_vad_jobbar_din_man_med"
  },
  {
    "contentId": "b1_dialog_line_002_04",
    "audioType": "dialogue_line_group",
    "sourceText": "Han arbetar på ett kontor. Jobbet är bra men staden är stor och bussen tar lång tid.",
    "audioRef": "sv_b1_u1_dialog_002_line_04_han_arbetar_pa_ett_kontor_jobbet_ar_bra_men_staden_ar_stor_och_bussen_tar_lang_t"
  },
  {
    "contentId": "b1_dialog_line_002_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Har du en nyckel till huset?",
    "audioRef": "sv_b1_u1_dialog_002_line_05_har_du_en_nyckel_till_huset"
  },
  {
    "contentId": "b1_dialog_line_002_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Ja, jag har nyckeln. Mitt rum har ett eget kök.",
    "audioRef": "sv_b1_u1_dialog_002_line_06_ja_jag_har_nyckeln_mitt_rum_har_ett_eget_kok"
  },
