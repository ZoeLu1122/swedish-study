    },
    {
      "audioId": "sv_a2_u2_dialog_001_line_01",
      "sourceText": "Ursäkta! Vad är klockan?",
      "fileName": "a1_u2_dialog_001_line_01_ursakta_vad_ar_klockan_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_001_line_01_ursakta_vad_ar_klockan_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_001_line_02",
      "sourceText": "Klockan är kvart i nio.",
      "fileName": "a1_u2_dialog_001_line_02_klockan_ar_kvart_i_nio_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_001_line_02_klockan_ar_kvart_i_nio_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_001_line_03",
      "sourceText": "Tack! Nästa buss går klockan nio, eller?",
      "fileName": "a1_u2_dialog_001_line_03_tack_nasta_buss_gar_klockan_nio_eller_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_001_line_03_tack_nasta_buss_gar_klockan_nio_eller_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_001_line_04",
      "sourceText": "Ja, klockan nio och sedan halv tio.",
      "fileName": "a1_u2_dialog_001_line_04_ja_klockan_nio_och_sedan_halv_tio_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_001_line_04_ja_klockan_nio_och_sedan_halv_tio_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_001_line_05",
      "sourceText": "Perfekt, tack så mycket!",
      "fileName": "a1_u2_dialog_001_line_05_perfekt_tack_sa_mycket_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_001_line_05_perfekt_tack_sa_mycket_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_002_line_01",
      "sourceText": "Hej! Välkommen till Vårdcentralen. Vad kan jag hjälpa dig med?",
      "fileName": "a1_u2_dialog_002_line_01_hej_valkommen_till_vardcentralen_vad_kan_jag_hjalpa_dig_med_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_002_line_01_hej_valkommen_till_vardcentralen_vad_kan_jag_hjalpa_dig_med_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_002_line_02",
      "sourceText": "Hej! Jag vill boka en tid, tack.",
      "fileName": "a1_u2_dialog_002_line_02_hej_jag_vill_boka_en_tid_tack_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_002_line_02_hej_jag_vill_boka_en_tid_tack_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_002_line_03",
      "sourceText": "Vilken dag passar dig?",
      "fileName": "a1_u2_dialog_002_line_03_vilken_dag_passar_dig_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_002_line_03_vilken_dag_passar_dig_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_002_line_04",
      "sourceText": "Är tisdag bra?",
      "fileName": "a1_u2_dialog_002_line_04_ar_tisdag_bra_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_002_line_04_ar_tisdag_bra_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_002_line_05",
      "sourceText": "Ja! Vi har en tid tisdag den femtonde mars, klockan tio.",
      "fileName": "a1_u2_dialog_002_line_05_ja_vi_har_en_tid_tisdag_den_femtonde_mars_klockan_tio_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_002_line_05_ja_vi_har_en_tid_tisdag_den_femtonde_mars_klockan_tio_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a2_u2_dialog_002_line_06",
      "sourceText": "Perfekt! Tack så mycket.",
      "fileName": "a1_u2_dialog_002_line_06_perfekt_tack_sa_mycket_v1.mp3",
      "filePath": "/audio/sv/a2/unit2/dialogue/a1_u2_dialog_002_line_06_perfekt_tack_sa_mycket_v1.mp3",
      "status": "ready"
    },
