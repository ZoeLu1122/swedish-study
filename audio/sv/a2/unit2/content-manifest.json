    {
      "contentId": "a2_dialog_line_001_01",
      "audioType": "dialogue_line_group",
      "sourceText": "Ursäkta! Vad är klockan?",
      "audioRef": "sv_a2_u2_dialog_001_line_01"
    },
    {
      "contentId": "a2_dialog_line_001_02",
      "audioType": "dialogue_line_group",
      "sourceText": "Klockan är kvart i nio.",
      "audioRef": "sv_a2_u2_dialog_001_line_02"
    },
    {
      "contentId": "a2_dialog_line_001_03",
      "audioType": "dialogue_line_group",
      "sourceText": "Tack! Nästa buss går klockan nio, eller?",
      "audioRef": "sv_a2_u2_dialog_001_line_03"
    },
    {
      "contentId": "a2_dialog_line_001_04",
      "audioType": "dialogue_line_group",
      "sourceText": "Ja, klockan nio och sedan halv tio.",
      "audioRef": "sv_a2_u2_dialog_001_line_04"
    },
    {
      "contentId": "a2_dialog_line_001_05",
      "audioType": "dialogue_line_group",
      "sourceText": "Perfekt, tack så mycket!",
      "audioRef": "sv_a2_u2_dialog_001_line_05"
    },
    {
      "contentId": "a2_dialog_line_002_01",
      "audioType": "dialogue_line_group",
      "sourceText": "Hej! Välkommen till Vårdcentralen. Vad kan jag hjälpa dig med?",
      "audioRef": "sv_a2_u2_dialog_002_line_01"
    },
    {
      "contentId": "a2_dialog_line_002_02",
      "audioType": "dialogue_line_group",
      "sourceText": "Hej! Jag vill boka en tid, tack.",
      "audioRef": "sv_a2_u2_dialog_002_line_02"
    },
    {
      "contentId": "a2_dialog_line_002_03",
      "audioType": "dialogue_line_group",
      "sourceText": "Vilken dag passar dig?",
      "audioRef": "sv_a2_u2_dialog_002_line_03"
    },
    {
      "contentId": "a2_dialog_line_002_04",
      "audioType": "dialogue_line_group",
      "sourceText": "Är tisdag bra?",
      "audioRef": "sv_a2_u2_dialog_002_line_04"
    },
    {
      "contentId": "a2_dialog_line_002_05",
      "audioType": "dialogue_line_group",
      "sourceText": "Ja! Vi har en tid tisdag den femtonde mars, klockan tio.",
      "audioRef": "sv_a2_u2_dialog_002_line_05"
    },
    {
      "contentId": "a2_dialog_line_002_06",
      "audioType": "dialogue_line_group",
      "sourceText": "Perfekt! Tack så mycket.",
      "audioRef": "sv_a2_u2_dialog_002_line_06"
    },
