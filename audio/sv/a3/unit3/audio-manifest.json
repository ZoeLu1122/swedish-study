    {
      "audioId": "sv_a3_u3_dialog_001_01",
      "sourceText": "Berätta om din familj!",
      "fileName": "a1_u3_dialog_001_line_01_beratta_om_din_familj_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_001_line_01_beratta_om_din_familj_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_001_02",
      "sourceText": "Jag har en man och två barn. Min man heter David och han är lärare.",
      "fileName": "a1_u3_dialog_001_line_02_jag_har_en_man_och_tva_barn_min_man_heter_david_och_han_ar_larare_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_001_line_02_jag_har_en_man_och_tva_barn_min_man_heter_david_och_han_ar_larare_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_001_03",
      "sourceText": "Hur gamla är barnen?",
      "fileName": "a1_u3_dialog_001_line_03_hur_gamla_ar_barnen_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_001_line_03_hur_gamla_ar_barnen_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_001_04",
      "sourceText": "De är fem och åtta år gamla.",
      "fileName": "a1_u3_dialog_001_line_04_de_ar_fem_och_atta_ar_gamla_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_001_line_04_de_ar_fem_och_atta_ar_gamla_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_001_05",
      "sourceText": "Bor ni i en lägenhet eller i ett hus?",
      "fileName": "a1_u3_dialog_001_line_05_bor_ni_i_en_lagenhet_eller_i_ett_hus_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_001_line_05_bor_ni_i_en_lagenhet_eller_i_ett_hus_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_001_06",
      "sourceText": "Vi bor i en lägenhet i Malmö. Det finns tre rum och ett kök.",
      "fileName": "a1_u3_dialog_001_line_06_vi_bor_i_en_lagenhet_i_malmo_det_finns_tre_rum_och_ett_kok_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_001_line_06_vi_bor_i_en_lagenhet_i_malmo_det_finns_tre_rum_och_ett_kok_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_002_01",
      "sourceText": "Hej! Jag är din nya granne. Jag heter Sara.",
      "fileName": "a1_u3_dialog_002_line_01_hej_jag_ar_din_nya_granne_jag_heter_sara_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_002_line_01_hej_jag_ar_din_nya_granne_jag_heter_sara_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_002_02",
      "sourceText": "Hej Sara! Välkommen! Jag heter Wei.",
      "fileName": "a1_u3_dialog_002_line_02_hej_sara_valkommen_jag_heter_wei_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_002_line_02_hej_sara_valkommen_jag_heter_wei_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_002_03",
      "sourceText": "Är det en stor lägenhet?",
      "fileName": "a1_u3_dialog_002_line_03_ar_det_en_stor_lagenhet_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_002_line_03_ar_det_en_stor_lagenhet_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_002_04",
      "sourceText": "Ja, det finns tre rum, ett kök och ett badrum. Det är mycket mysigt!",
      "fileName": "a1_u3_dialog_002_line_04_ja_det_finns_tre_rum_ett_kok_och_ett_badrum_det_ar_mycket_mysigt_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_002_line_04_ja_det_finns_tre_rum_ett_kok_och_ett_badrum_det_ar_mycket_mysigt_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_002_05",
      "sourceText": "Bor du ensam?",
      "fileName": "a1_u3_dialog_002_line_05_bor_du_ensam_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_002_line_05_bor_du_ensam_v1.mp3",
      "status": "ready"
    },
    {
      "audioId": "sv_a3_u3_dialog_002_06",
      "sourceText": "Nej, jag bor med min man och vår dotter.",
      "fileName": "a1_u3_dialog_002_line_06_nej_jag_bor_med_min_man_och_var_dotter_v1.mp3",
      "filePath": "/audio/sv/a3/unit3/dialogue/a1_u3_dialog_002_line_06_nej_jag_bor_med_min_man_och_var_dotter_v1.mp3",
      "status": "ready"
    },
