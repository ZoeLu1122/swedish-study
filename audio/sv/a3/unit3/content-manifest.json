  {
    "contentId": "a3_dialog_line_001_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Berätta om din familj!",
    "audioRef": "sv_a3_u3_dialog_001_01"
  },
  {
    "contentId": "a3_dialog_line_001_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Jag har en man och två barn. Min man heter David och han är lärare.",
    "audioRef": "sv_a3_u3_dialog_001_02"
  },
  {
    "contentId": "a3_dialog_line_001_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Hur gamla är barnen?",
    "audioRef": "sv_a3_u3_dialog_001_03"
  },
  {
    "contentId": "a3_dialog_line_001_04",
    "audioType": "dialogue_line_group",
    "sourceText": "De är fem och åtta år gamla.",
    "audioRef": "sv_a3_u3_dialog_001_04"
  },
  {
    "contentId": "a3_dialog_line_001_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Bor ni i en lägenhet eller i ett hus?",
    "audioRef": "sv_a3_u3_dialog_001_05"
  },
  {
    "contentId": "a3_dialog_line_001_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Vi bor i en lägenhet i Malmö. Det finns tre rum och ett kök.",
    "audioRef": "sv_a3_u3_dialog_001_06"
  },
  {
    "contentId": "a3_dialog_line_002_01",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej! Jag är din nya granne. Jag heter Sara.",
    "audioRef": "sv_a3_u3_dialog_002_01"
  },
  {
    "contentId": "a3_dialog_line_002_02",
    "audioType": "dialogue_line_group",
    "sourceText": "Hej Sara! Välkommen! Jag heter Wei.",
    "audioRef": "sv_a3_u3_dialog_002_02"
  },
  {
    "contentId": "a3_dialog_line_002_03",
    "audioType": "dialogue_line_group",
    "sourceText": "Är det en stor lägenhet?",
    "audioRef": "sv_a3_u3_dialog_002_03"
  },
  {
    "contentId": "a3_dialog_line_002_04",
    "audioType": "dialogue_line_group",
    "sourceText": "Ja, det finns tre rum, ett kök och ett badrum. Det är mycket mysigt!",
    "audioRef": "sv_a3_u3_dialog_002_04"
  },
  {
    "contentId": "a3_dialog_line_002_05",
    "audioType": "dialogue_line_group",
    "sourceText": "Bor du ensam?",
    "audioRef": "sv_a3_u3_dialog_002_05"
  },
  {
    "contentId": "a3_dialog_line_002_06",
    "audioType": "dialogue_line_group",
    "sourceText": "Nej, jag bor med min man och vår dotter.",
    "audioRef": "sv_a3_u3_dialog_002_06"
  },
